# ===========================================
# Jira Profile Configuration
# ===========================================
# Copy this file to .env and fill in your credentials.
#   cp .env.example .env
#
# Set the active profile below. The .envrc will
# load credentials for this profile into the
# standard JIRA_* variables used by mcp.json.
#
# Available profiles: dev, staging, prod
# ===========================================

JIRA_PROFILE=dev

# -------------------------------------------
# Profile: dev
# -------------------------------------------
JIRA_DEV_URL=https://your-dev-domain.atlassian.net
JIRA_DEV_USERNAME=your-dev-email@company.com
JIRA_DEV_API_TOKEN=your-dev-api-token
JIRA_DEV_PROJECT_KEY=DEV

# -------------------------------------------
# Profile: staging
# -------------------------------------------
JIRA_STAGING_URL=https://your-staging-domain.atlassian.net
JIRA_STAGING_USERNAME=your-staging-email@company.com
JIRA_STAGING_API_TOKEN=your-staging-api-token
JIRA_STAGING_PROJECT_KEY=STG

# -------------------------------------------
# Profile: prod
# -------------------------------------------
JIRA_PROD_URL=https://your-prod-domain.atlassian.net
JIRA_PROD_USERNAME=your-prod-email@company.com
JIRA_PROD_API_TOKEN=your-prod-api-token
JIRA_PROD_PROJECT_KEY=PROD
